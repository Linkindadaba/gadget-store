# Copy this file to `.env` and fill real values. NEVER commit `.env`.

# Django core
SECRET_KEY=replace_with_a_strong_secret_key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost

# Database - production: set DATABASE_URL (preferred)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Paystack (server-side secret)
PAYSTACK_SECRET_KEY=sk_test_or_live_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_or_live_replace_me
PAYSTACK_WEBHOOK_SECRET=replace_with_webhook_secret
PAYSTACK_ALLOWED_IPS=

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_or_live_replace_me
FLUTTERWAVE_ENCRYPTION_KEY=replace_with_encryption_key
FLUTTERWAVE_WEBHOOK_SECRET=replace_with_webhook_secret
FLUTTERWAVE_BASE_URL=https://developersandbox-api.flutterwave.com
FLUTTERWAVE_CURRENCY=GHS

# Sentry (optional)
SENTRY_DSN=

# Email
DEFAULT_FROM_EMAIL=webmaster@localhost
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
PASSWORD_RESET_TIMEOUT=3600

# Guidance:
# - After creating .env, keep it outside Git; the repo .gitignore contains `.env`.
# - Rotate any keys that were committed to this repository immediately.
