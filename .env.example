# Django settings
SECRET_KEY=your-super-secret-key-change-this
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,app.railway.app

# Flutterwave v4 (sandbox by default)
FLUTTERWAVE_CLIENT_ID=your_client_id
FLUTTERWAVE_CLIENT_SECRET=your_client_secret
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key
FLUTTERWAVE_BASE_URL=https://developersandbox-api.flutterwave.com
FLUTTERWAVE_CURRENCY=GHS

# Database (optional - Railway provides DATABASE_URL)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Paystack
# Set your Paystack keys here. Use the secret key on the server only.
PAYSTACK_SECRET_KEY=PAYSTACK_TEST_xxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=PAYSTACK_TEST_xxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
