{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "preDeployCommand": "cd /app/gadget_store && python manage.py migrate --noinput",
    "startCommand": "gunicorn gadget_store.wsgi --bind 0.0.0.0:8000 --workers 2 --timeout 120"
  }
}


